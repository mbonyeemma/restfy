# Copy to `.env` in this folder (gitignored). Never commit real secrets.

# Required for JWT auth
JWT_SECRET=change-me-to-a-long-random-string

# Transactional email (Resend — https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx

# Sender shown in emails (must be allowed in your Resend account / domain)
RESTIFY_EMAIL_FROM=Restify <onboarding@resend.dev>

# Optional: cross-subdomain auth cookie (e.g. .restify.online)
# RESTIFY_AUTH_COOKIE_DOMAIN=.restify.online
