# Copy to `.env` in this folder (gitignored). Never commit real secrets.

# Required for JWT auth
JWT_SECRET=change-me-to-a-long-random-string

# Transactional email (Resend — https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxx

# Sender shown in emails (must be allowed in your Resend account / domain)
RESTIFY_EMAIL_FROM=Restify <onboarding@resend.dev>
# For production, use a verified domain (e.g. noreply@restify.online). Resend’s
# onboarding@resend.dev often only delivers to your own signup email — invites to
# other addresses need a verified sender domain.

# Optional: URLs embedded in transactional emails (defaults match restify.online)
# RESTIFY_PUBLIC_WEBSITE_ORIGIN=https://restify.online
# RESTIFY_PUBLIC_APP_ORIGIN=https://app.restify.online
# RESTIFY_PUBLIC_DOWNLOAD_URL=https://restify.online/#get
# RESTIFY_PUBLIC_API_ORIGIN=https://api.restify.online

# Optional: cross-subdomain auth cookie (e.g. .restify.online)
# RESTIFY_AUTH_COOKIE_DOMAIN=.restify.online
