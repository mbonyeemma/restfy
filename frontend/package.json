{
  "name": "restfy",
  "version": "2.0.0",
  "description": "Restfy – A free, open-source Postman alternative for macOS",
  "main": "main.js",
  "scripts": {
    "start": "http-server . -p 8787 -c-1 -o /app.html",
    "dev": "http-server . -p 8787 -c-1 -o /app.html",
    "web": "npm run start",
    "electron": "electron .",
    "server": "npm --prefix ../server run dev",
    "server:build": "npm --prefix ../server run build",
    "server:start": "npm --prefix ../server run start",
    "build:mac": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mbonyeemma/restfy.git"
  },
  "author": "mbonyeemma",
  "license": "MIT",
  "build": {
    "appId": "com.restfy.app",
    "productName": "Restfy",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png"
    },
    "dmg": {
      "title": "Restfy"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "app.html",
      "docs.html",
      "js/**",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "http-server": "^14.1.1"
  }
}
