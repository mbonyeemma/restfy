{
  "name": "restfy",
  "version": "2.0.0",
  "description": "Restfy – A free, open-source Postman alternative for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mbonyeemma/restfy.git"
  },
  "author": "mbonyeemma",
  "license": "MIT",
  "build": {
    "appId": "com.restfy.app",
    "productName": "Restfy",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns"
    },
    "dmg": {
      "title": "Restfy"
    },
    "files": [
      "app.html",
      "main.js",
      "preload.js",
      "js/**",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
