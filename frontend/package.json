{
  "name": "restify-client",
  "version": "1.0.1",
  "description": "Restify — A free, open-source Postman alternative for macOS",
  "main": "out/main/index.js",
  "scripts": {
    "start": "npm run build && node scripts/serve-web.cjs",
    "serve:web": "node scripts/serve-web.cjs",
    "build:web": "electron-vite build",
    "dev": "electron-vite dev",
    "dev:web": "electron-vite dev --mode web",
    "build": "electron-vite build",
    "electron": "electron-vite dev",
    "preview": "electron-vite preview",
    "server": "npm --prefix ../server run dev",
    "server:build": "npm --prefix ../server run build",
    "server:start": "npm --prefix ../server run start",
    "build:mac": "npm run build && electron-builder --mac",
    "build:dmg": "npm run build && electron-builder --mac dmg --publish never",
    "publish:dmg": "npm run build && npx dotenv-cli -e .env -- electron-builder --mac dmg --publish always",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mbonyeemma/restfy.git"
  },
  "author": "mbonyeemma",
  "license": "MIT",
  "build": {
    "appId": "com.restify.app",
    "productName": "Restify",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "mbonyeemma",
      "repo": "restfy"
    },
    "files": [
      "out/**"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dotenv-cli": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "electron-updater": "^6.8.3",
    "http-server": "^14.1.1"
  }
}
